rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated (admin)
    function isAdmin() {
      return request.auth != null;
    }

    // packages collection (Public read, Admin write)
    match /packages/{packageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // vehicles collection (Public read, Admin write)
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // gallery collection (Public read, Admin write)
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // kodai collections (Public read, Admin write)
    match /kodai_tours/{tourId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /kodai_safaris/{safariId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /kodai_stays/{stayId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /kodai_sightseeing/{sightseeingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // settings collection (Public read, Admin write)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // enquiries collection (Public create, Admin read/update/delete)
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // newsletter collection (Public create, Admin read/update/delete)
    match /newsletter/{newsletterId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // profile collection (Admin only)
    match /profile/{profileId} {
      allow read, write: if isAdmin();
    }
  }
}
